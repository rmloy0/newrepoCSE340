<h1><%= title %></h1>
<%- messages() %>

<% if (errors) { %>
  <ul class="notice">
 <% errors.array().forEach(error => { %>
   <li><%- error.msg %></li>
<%  }) %>
 </ul>
<% } %>

<h1>Delete Inventory</h1>

<div class="form-view">
  <form action="/inv/delete" method="post">
<p>Confirm Deletion - The delete is permanent.</p>
   

  
    <label for="inv_make">Make</label>
    <input type="text" id="inv_make" name="inv_make" required minlength="3"
      value="<%= inv_make %>" readonly>

    <label for="inv_model">Model</label>
    <input type="text" id="inv_model" name="inv_model" required minlength="3"
      value="<%= inv_model %>" readonly>

    
 
    <label for="inv_price">Price</label>
    <input type="number" id="inv_price" name="inv_price" required
      value="<%= inv_price %>" readonly>

    <label for="inv_year">Year</label>
    <input type="number" id="inv_year" name="inv_year" min="1900" max="2026" required
      value="<%= inv_year %>" readonly>
    <input type="hidden" name="inv_id" value="<%= inv_id %>">
 

 

    <div class="button-container">
      <input type="submit" class="button-submit" value="delete Inventory">

 
    </div>
  </form>
</div>
